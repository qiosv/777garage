# Локально: скопируй как `.env.local` и подставь значения (файл `.env.local` в git не попадает).
# На Cloudflare Pages: Workers & Pages → 777-garage → Settings → Environment variables
# (имена должны совпадать — Vite подставляет их при сборке).

# Google Analytics 4 — измерение вида G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=

# Google Ads — только если используешь тег из кабинета Ads
VITE_GOOGLE_ADS_ID=
